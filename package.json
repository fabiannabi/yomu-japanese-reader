{
  "name": "yomu",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "postinstall": "node scripts/copy-dict.mjs",
    "predev": "node scripts/copy-dict.mjs",
    "prebuild": "node scripts/copy-dict.mjs",
    "dev": "vite",
